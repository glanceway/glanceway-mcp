{
  "name": "glanceway-mcp",
  "version": "1.1.0",
  "type": "module",
  "bin": {
    "glanceway-mcp": "dist/mcpb/server/index.mjs"
  },
  "files": [
    "dist/mcpb/server/index.mjs"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --banner:js='#!/usr/bin/env node' --define:PKG_VERSION=\\\"$npm_package_version\\\" --outfile=dist/mcpb/server/index.mjs",
    "pack": "npm run build && cp manifest.json icon.png dist/mcpb/ && cd dist/mcpb && zip -r ../glanceway.mcpb .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.24.0",
    "typescript": "^6.0.2"
  }
}
